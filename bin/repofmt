#!/usr/bin/env bash
set -euo pipefail

load_node_tooling() {
  if command -v node >/dev/null 2>&1; then
    return
  fi

  if command -v fnm >/dev/null 2>&1; then
    export FNM_DIR="${FNM_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/fnm}"
    # shellcheck disable=SC1090
    eval "$(fnm env --shell bash)"

    if [[ -f .nvmrc || -f .node-version || -f package.json ]]; then
      fnm use --install-if-missing --silent-if-unchanged >/dev/null 2>&1 || true
    fi

    if ! command -v node >/dev/null 2>&1; then
      fnm use default --silent-if-unchanged >/dev/null 2>&1 || true
    fi
  fi
}

find_cmd() {
  local local_path="$1"
  local global_name="$2"

  if [[ -x "$local_path" ]]; then
    printf '%s\n' "$local_path"
    return 0
  fi

  if command -v "$global_name" >/dev/null 2>&1; then
    command -v "$global_name"
    return 0
  fi

  return 1
}

package_json_has() {
  local pattern="$1"

  [[ -f package.json ]] && grep -q "$pattern" package.json
}

has_any_file() {
  local path

  for path in "$@"; do
    if [[ -f "$path" ]]; then
      return 0
    fi
  done

  return 1
}

collect_default_files() {
  git ls-files -m -o --exclude-standard -z
}

collect_staged_files() {
  git diff --cached --name-only --diff-filter=ACMR -z
}

collect_all_files() {
  git ls-files -z
}

restage_files() {
  local files=("$@")

  if [[ ${#files[@]} -gt 0 ]]; then
    git add -- "${files[@]}"
  fi
}

usage() {
  cat <<'EOF'
Usage: repofmt [--staged | --all] [file ...]

Formats files using the repo's configured formatter stack.

Options:
  --staged   Format staged files and re-stage them after formatting
  --all      Format all tracked files in the repository
  --help     Show this help

Examples:
  repofmt
  repofmt src/app.ts
  repofmt --staged
  repofmt --all
EOF
}

main() {
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    printf '%s\n' "Not inside a git repository." >&2
    exit 1
  fi

  local repo_root
  repo_root="$(git rev-parse --show-toplevel)"
  cd "$repo_root"

  load_node_tooling

  local staged_mode=0
  local all_mode=0
  local all_files=()
  local format_files=()
  local js_files=()
  local biome_files=()
  local path

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --staged)
        staged_mode=1
        shift
        ;;
      --all)
        all_mode=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      --)
        shift
        break
        ;;
      -*)
        printf 'Unknown option: %s\n' "$1" >&2
        usage >&2
        exit 1
        ;;
      *)
        break
        ;;
    esac
  done

  if [[ "$staged_mode" -eq 1 && "$all_mode" -eq 1 ]]; then
    printf '%s\n' "repofmt: --staged and --all cannot be combined." >&2
    exit 1
  fi

  if [[ "$staged_mode" -eq 1 && $# -gt 0 ]]; then
    printf '%s\n' "repofmt: --staged cannot be combined with explicit file paths." >&2
    exit 1
  fi

  if [[ "$all_mode" -eq 1 && $# -gt 0 ]]; then
    printf '%s\n' "repofmt: --all cannot be combined with explicit file paths." >&2
    exit 1
  fi

  if [[ $# -gt 0 ]]; then
    for path in "$@"; do
      [[ -f "$path" ]] || continue
      all_files+=("$path")
    done
  elif [[ "$all_mode" -eq 1 ]]; then
    while IFS= read -r -d '' path; do
      [[ -f "$path" ]] || continue
      all_files+=("$path")
    done < <(collect_all_files)
  elif [[ "$staged_mode" -eq 1 ]]; then
    while IFS= read -r -d '' path; do
      [[ -f "$path" ]] || continue
      all_files+=("$path")
    done < <(collect_staged_files)
  else
    while IFS= read -r -d '' path; do
      [[ -f "$path" ]] || continue
      all_files+=("$path")
    done < <(collect_default_files)
  fi

  if [[ ${#all_files[@]} -eq 0 ]]; then
    exit 0
  fi

  for path in "${all_files[@]}"; do
    case "$path" in
      *.js|*.cjs|*.mjs|*.jsx|*.ts|*.tsx)
        js_files+=("$path")
        format_files+=("$path")
        biome_files+=("$path")
        ;;
      *.json|*.json5|*.jsonc|*.css|*.scss|*.html|*.md|*.mdx|*.yml|*.yaml|*.graphql|*.gql)
        format_files+=("$path")
        ;;
    esac

    case "$path" in
      *.css|*.graphql|*.gql)
        biome_files+=("$path")
        ;;
    esac
  done

  local ran_tool=0
  local biome_cmd=""
  local prettier_cmd=""
  local eslint_cmd=""

  if biome_cmd="$(find_cmd "node_modules/.bin/biome" "biome" 2>/dev/null)" && \
    (has_any_file biome.json biome.jsonc || package_json_has '"@biomejs/biome"' || package_json_has '"biome"'); then
    if [[ ${#biome_files[@]} -gt 0 ]]; then
      "$biome_cmd" check --write --no-errors-on-unmatched --files-ignore-unknown=true "${biome_files[@]}"
      [[ "$staged_mode" -eq 1 ]] && restage_files "${biome_files[@]}"
      ran_tool=1
    fi
  fi

  if prettier_cmd="$(find_cmd "node_modules/.bin/prettier" "prettier" 2>/dev/null)" && \
    (has_any_file .prettierrc .prettierrc.json .prettierrc.yml .prettierrc.yaml .prettierrc.json5 .prettierrc.js .prettierrc.cjs .prettierrc.mjs prettier.config.js prettier.config.cjs prettier.config.mjs || package_json_has '"prettier"'); then
    if [[ ${#format_files[@]} -gt 0 ]]; then
      "$prettier_cmd" --write "${format_files[@]}"
      [[ "$staged_mode" -eq 1 ]] && restage_files "${format_files[@]}"
      ran_tool=1
    fi
  fi

  if eslint_cmd="$(find_cmd "node_modules/.bin/eslint" "eslint" 2>/dev/null)" && \
    (has_any_file eslint.config.js eslint.config.cjs eslint.config.mjs eslint.config.ts .eslintrc .eslintrc.js .eslintrc.cjs .eslintrc.json .eslintrc.yml .eslintrc.yaml || package_json_has '"eslintConfig"' || package_json_has '"eslint"'); then
    if [[ ${#js_files[@]} -gt 0 ]]; then
      "$eslint_cmd" --fix "${js_files[@]}"
      [[ "$staged_mode" -eq 1 ]] && restage_files "${js_files[@]}"
      ran_tool=1
    fi
  fi

  if [[ "$ran_tool" -eq 0 ]]; then
    printf '%s\n' "No supported repo formatter detected. Skipping formatting." >&2
  fi
}

main "$@"
