[user]
	name = Aleix Alonso
	email = aleixalonso@hotmail.com
	signingkey = ~/.ssh/github_key.pub

[gpg]
	format = ssh

[commit]
	gpgsign = true
	verbose = true

[core]
	excludesfile = ~/.gitignore_global
	editor = cursor --wait
	pager = less -FRX

[init]
	defaultBranch = main

[pull]
	ff = only

[push]
	autoSetupRemote = true
	default = simple

[fetch]
	prune = true
	pruneTags = true

[rebase]
	autoStash = true
	updateRefs = true

[rerere]
	enabled = true
	autoupdate = true

[merge]
	conflictstyle = zdiff3

[diff]
	algorithm = histogram
	colorMoved = default

[branch]
	sort = -committerdate

[tag]
	sort = version:refname

[status]
	short = true
	branch = true

[color]
	ui = auto

[alias]
	st = status --short --branch
	co = checkout
	sw = switch
	br = branch --sort=-committerdate
	lg = log --graph --decorate --oneline --all
	last = log -1 --stat
	amend = commit --amend --no-edit
	uncommit = reset --soft HEAD~1
	unstage = restore --staged --
