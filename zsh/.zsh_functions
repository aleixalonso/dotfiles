load-nvmrc() {
  local nvm_default_version

  command -v nvm >/dev/null 2>&1 || return
  nvm_default_version="$(nvm version default)"

  if [[ -f .nvmrc && -r .nvmrc ]]; then
    nvm use
  elif [[ "$nvm_default_version" != "N/A" && "$(nvm version)" != "$nvm_default_version" ]]; then
    echo "Reverting to nvm default version"
    nvm use default
  fi
}

gup() {
  if [[ -z "$1" ]]; then
    echo "usage: gup <branch>" >&2
    return 1
  fi

  git switch "$1" && git up
}

grebase() {
  local interactive target current
  interactive=0

  if [[ "$1" == "-i" ]]; then
    interactive=1
    shift
  fi

  target="$1"

  if [[ -z "$target" ]]; then
    echo "usage: grebase [-i] <branch>" >&2
    return 1
  fi

  current="$(git branch --show-current)" || return 1

  if [[ "$current" == "$target" ]]; then
    echo "already on $target" >&2
    return 1
  fi

  git switch "$target" &&
  git up &&
  git switch "$current" &&
  if (( interactive )); then
    git rebase -i "$target"
  else
    git rebase "$target"
  fi &&
  echo "Rebase finished. If this branch was previously pushed, use: git push --force-with-lease"
}
